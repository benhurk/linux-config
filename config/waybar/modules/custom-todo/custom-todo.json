{
  "custom/todo": {
    "exec": "~/.config/waybar/scripts/todo.sh",
    "interval": 5,
    "return-type": "json",
    "signal": 2,
    "format": "󱍧",
    "tooltip-format": "\r<b> {text}</b>\r\r{alt}",
    "on-click": "todo set --next; pkill -RTMIN+2 waybar",
    "on-click-right": "todo set --prev; pkill -RTMIN+2 waybar",
    "on-click-middle": "todo rm --current; pkill -RTMIN+2 waybar"
  }
}
