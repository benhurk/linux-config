// https://github.com/Alexays/Waybar/wiki/Module:-PulseAudio

{
  "pulseaudio": {
    "scroll-step": 5,
    "format": "<span font='16px'>󰕾</span> <span rise='1000'>{volume}%</span>",
    "format-muted": "<span font='16px'>󰖁</span> <span rise='1000'>0%</span>",
    "tooltip": false,
    "on-click": "pamixer -t",
    "on-click-right": "pavucontrol"
  }
}
